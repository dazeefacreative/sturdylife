# Database (Railway's MySQL plugin provides these values directly)
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Paystack
PAYSTACK_SECRET_KEY=

# CORS — comma-separated list of allowed origins (e.g. Netlify URL + localhost for dev)
FRONTEND_URL=http://localhost:5173,https://sturdylife.netlify.app

# Email — SMTP creds used to send order receipts + admin order alerts.
# Works with a Gmail App Password for now (smtp.gmail.com, port 465), or swap
# to Namecheap Private Email / any SMTP provider later without code changes.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_EMAIL=

# Server
PORT=3000
NODE_ENV=production
