# Database (Railway's MySQL plugin provides these values directly)
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Paystack
PAYSTACK_SECRET_KEY=

# CORS — set to your deployed Netlify URL in production
FRONTEND_URL=http://localhost:5173

# Server
PORT=3000
NODE_ENV=production
