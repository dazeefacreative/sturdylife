# Database — create these via cPanel > MySQL Databases first.
# cPanel prefixes both the DB name and user with your cPanel username,
# e.g. DB_NAME=sturdylif_sturdy_life, DB_USER=sturdylif_admin
DB_HOST=localhost
DB_USER=
DB_PASSWORD=
DB_NAME=

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Paystack
PAYSTACK_SECRET_KEY=

# CORS — comma-separated list of allowed origins (production domain + localhost for dev)
FRONTEND_URL=http://localhost:5173,https://sturdylifer.com

# Primary public URL used for Paystack callback redirect (single URL, no commas)
APP_URL=https://sturdylifer.com

# Email — SMTP creds used to send order receipts + admin order alerts.
# Namecheap Private Email works out of the box once the mailbox is created
# in cPanel > Email Accounts (mail.sturdylifer.com, port 465, SSL).
SMTP_HOST=mail.sturdylifer.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_EMAIL=

# Server
PORT=3000
NODE_ENV=production
